# Example frontend environment variables for Vite (Vercel deployment)
# Set this in Vercel dashboard to your Render backend public URL
# Example: https://your-backend.onrender.com/api
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# Demo webcam API key (for testing/dev only)
VITE_DEMO_WEBCAM_KEY=demo-webcam-api-key-for-testing-1234567890abcdef0123456789abcdef

# Firebase config (get these from your Firebase Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase VAPID key for FCM web push
VITE_FIREBASE_VAPID_KEY=
