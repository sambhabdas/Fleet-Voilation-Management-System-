# Backend environment variables for Render deployment
# Copy these to the Render dashboard, do not commit secrets

# PostgreSQL connection string (Render provides this or use an external DB)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

# Security keys (change in production)
SECRET_KEY=your-production-secret-key
WEBHOOK_API_KEY=your-production-webhook-key

# JWT token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS: set to your deployed Vercel frontend URL
CORS_ORIGINS=https://your-frontend.vercel.app

# Optional: Path to Google FCM service account JSON (if using push notifications)
FCM_SERVICE_ACCOUNT_PATH=
